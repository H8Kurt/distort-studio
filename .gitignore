```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Logs and temp files
*.log
*.tmp

# Environment variables
.env
.env.local
.env.*

# Editors
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage
coverage/
htmlcov/
.coverage

# OS generated files
.DS_Store
Thumbs.db
```