```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
.nuxt/
public/dist/
*.bundle.js
*.min.js
*.css.map

# Logs
*.log

# Environment variables
.env
.env.local
*.env

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.pytest_cache/
.mypy_cache/
.tox/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled binary files
*.exe
*.dll
*.so
*.dylib
*.class
*.jar
*.war
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.7z
*.rar
*.gz
*.bz2
*.xz
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
```